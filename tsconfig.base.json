{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@rewar/shared": ["packages/shared/src/index.ts"],
      "@rewar/shared/*": ["packages/shared/src/*"],
      "@rewar/rules": ["packages/rules/src/index.ts"],
      "@rewar/rules/*": ["packages/rules/src/*"]
    }
  }
}

